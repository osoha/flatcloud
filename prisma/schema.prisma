generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
  OWNER_VIEWER
  PROPERTY_MANAGER
}

enum PropertyPermission {
  VIEW
  EDIT
  ADMIN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum PaymentStatus {
  UNMATCHED
  SUGGESTED
  MATCHED
  PARTIAL
  OVERPAYMENT
  IGNORED
}

enum LeaseStatus {
  ACTIVE
  ENDED
  FUTURE
}

enum RentTiming {
  ADVANCE
  ARREARS
}

enum PropertyOwnershipMode {
  WHOLE_OBJECT
  UNIT_BASED
  SVJ
}

enum BankConnectionStatus {
  CONNECTED
  NEEDS_REAUTH
  ERROR
  DISCONNECTED
}

enum BankAuthorizationStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum MatchRuleAction {
  IGNORE
  MATCH_LEASE
  SUGGEST_LEASE
}

enum OwnerType {
  COMPANY
  PERSON
  SPV
}

enum UnitType {
  APARTMENT
  COMMERCIAL
  GARAGE
  PARKING
  STORAGE
  OTHER
}

enum UnitStatus {
  VACANT
  OCCUPIED
  RENOVATION
  INACTIVE
}

enum TenantType {
  PERSON
  COMPANY
}

enum MeterType {
  COLD_WATER
  HOT_WATER
  ELECTRICITY_HIGH_TARIFF
  ELECTRICITY_LOW_TARIFF
  GAS
}

enum ChargeCategory {
  RENT
  WATER
  HEATING
  ELECTRICITY
  SERVICES
  PARKING
  DEPOSIT
  OTHER
  ADJUSTMENT
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  role         UserRole       @default(OWNER_VIEWER)
  active       Boolean        @default(true)
  allProperties Boolean       @default(false)
  phone        String?
  title        String?
  avatarData   Bytes?
  avatarMimeType String?
  memberships       UserProperty[]
  unitMemberships   UserUnit[]
  invitationsSent   UserInvitation[] @relation("InvitationSender")
  bankAuthorizationsConnected BankAuthorization[] @relation("BankAuthorizationConnector")
  bankAccountsConnected       BankAccount[]       @relation("BankAccountConnector")
  managedProperties Property[] @relation("PropertyManager")
  auditLogs         AuditLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Owner {
  id                 String              @id @default(cuid())
  name               String
  type               OwnerType           @default(COMPANY)
  ico                String?
  email              String?
  phone              String?
  address            String?
  note               String?
  active             Boolean             @default(true)
  properties         Property[]
  propertyOwnerships PropertyOwnership[]
  unitOwnerships     UnitOwnership[]
  bankAccounts       BankAccount[]
  communicationProperties Property[] @relation("PropertyCommunicationOwner")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model Property {
  id                   String                  @id @default(cuid())
  name                 String
  address              String
  city                 String
  postalCode           String?
  note                 String?
  technicalData        Json?
  active               Boolean                 @default(true)
  ownerId              String
  owner                Owner                    @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  ownershipMode        PropertyOwnershipMode     @default(WHOLE_OBJECT)
  communicationOwnerId String?
  communicationOwner   Owner?                    @relation("PropertyCommunicationOwner", fields: [communicationOwnerId], references: [id], onDelete: SetNull)
  managerId            String?
  manager              User?                     @relation("PropertyManager", fields: [managerId], references: [id], onDelete: SetNull)
  ownerships           PropertyOwnership[]
  units                Unit[]
  bankAccounts         BankAccount[]
  bankAuthorizations   BankAuthorization[]
  matchingRules        BankMatchingRule[]
  memberships          UserProperty[]
  invitations          UserInvitation[]
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([ownerId])
  @@index([communicationOwnerId])
  @@index([managerId])
}

model PropertyOwnership {
  id               String   @id @default(cuid())
  propertyId       String
  ownerId          String
  shareBasisPoints Int      @default(10000)
  note             String?
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner            Owner    @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([propertyId, ownerId])
  @@index([ownerId])
}

model UserProperty {
  userId     String
  propertyId String
  permission PropertyPermission @default(VIEW)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([userId, propertyId])
  @@index([propertyId, permission])
}

model UserUnit {
  userId     String
  unitId     String
  permission PropertyPermission @default(VIEW)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit       Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([userId, unitId])
  @@index([unitId, permission])
}

model UserInvitation {
  id          String             @id @default(cuid())
  email       String
  name        String?
  tokenHash   String             @unique
  propertyId  String
  propertyIds String[]           @default([])
  unitIds     String[]           @default([])
  allProperties Boolean          @default(false)
  property    Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  permission  PropertyPermission @default(VIEW)
  invitedById String
  invitedBy   User               @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)
  status      InvitationStatus   @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([propertyId, status])
  @@index([email, status])
}

model AppSetting {
  id                   String   @id @default("global")
  automaticBankSync    Boolean  @default(true)
  bankSyncsPerDay      Int      @default(24)
  lastCronStartedAt    DateTime?
  lastCronFinishedAt   DateTime?
  lastCronSummary      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Unit {
  id         String          @id @default(cuid())
  label      String
  floor      String?
  type       UnitType        @default(APARTMENT)
  status     UnitStatus      @default(VACANT)
  areaM2     Float?
  note       String?
  propertyId String
  property   Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownerships UnitOwnership[]
  userAccesses UserUnit[]
  leases     Lease[]
  meters     Meter[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([propertyId, label])
  @@index([propertyId])
}

model UnitOwnership {
  id               String   @id @default(cuid())
  unitId           String
  ownerId          String
  shareBasisPoints Int      @default(10000)
  note             String?
  unit             Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  owner            Owner    @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([unitId, ownerId])
  @@index([ownerId])
}

model Tenant {
  id            String     @id @default(cuid())
  type          TenantType @default(PERSON)
  name          String
  email         String?
  phone         String?
  address       String?
  ico           String?
  permanentAddress      String?
  correspondenceAddress String?
  billingAddress        String?
  billingEmail          String?
  communicationEmail    String?
  note          String?
  active        Boolean    @default(true)
  payerAccounts String[]
  leases        Lease[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Lease {
  id                    String             @id @default(cuid())
  unitId                String
  tenantId              String
  unit                  Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contractNumber        String?
  startDate             DateTime
  endDate               DateTime?
  dueDay                Int                @default(5)
  variableSymbol        String
  currency              String             @default("CZK")
  rentTiming             RentTiming         @default(ADVANCE)
  rentCents             Int
  servicesCents         Int
  depositCents          Int                @default(0)
  note                  String?
  status                LeaseStatus        @default(ACTIVE)
  paymentItems          LeasePaymentItem[]
  charges               Charge[]
  matchingRules         BankMatchingRule[] @relation("RuleTargetLease")
  suggestedTransactions BankTransaction[]  @relation("SuggestedLease")
  occupants             Occupant[]
  meterReadings         MeterReading[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([unitId, variableSymbol])
  @@index([tenantId])
  @@index([variableSymbol])
}

model Occupant {
  id                    String   @id @default(cuid())
  leaseId               String
  lease                 Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  name                  String
  email                 String?
  phone                 String?
  permanentAddress      String?
  correspondenceAddress String?
  note                  String?
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([leaseId, active])
}

model Meter {
  id            String         @id @default(cuid())
  unitId        String
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  type          MeterType
  label         String?
  serialNumber  String?
  unitOfMeasure String
  active        Boolean        @default(true)
  readings      MeterReading[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([unitId, type])
}

model MeterReading {
  id        String   @id @default(cuid())
  meterId   String
  meter     Meter    @relation(fields: [meterId], references: [id], onDelete: Cascade)
  leaseId   String?
  lease     Lease?   @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  readAt    DateTime
  value     Float
  note      String?
  createdAt DateTime @default(now())

  @@index([meterId, readAt])
  @@index([leaseId])
}

model LeasePaymentItem {
  id          String         @id @default(cuid())
  leaseId     String
  lease       Lease          @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  name        String
  category    ChargeCategory @default(OTHER)
  amountCents Int
  validFrom   DateTime
  validTo     DateTime?
  active      Boolean        @default(true)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([leaseId, validFrom])
}

model Charge {
  id          String              @id @default(cuid())
  leaseId     String
  lease       Lease               @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  period      String
  dueDate     DateTime
  amountCents Int
  note        String?
  active      Boolean             @default(true)
  items       ChargeItem[]
  allocations PaymentAllocation[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([leaseId, period])
  @@index([leaseId, dueDate])
}

model ChargeItem {
  id          String         @id @default(cuid())
  chargeId    String
  charge      Charge         @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  name        String
  category    ChargeCategory @default(OTHER)
  amountCents Int
  createdAt   DateTime       @default(now())

  @@index([chargeId])
}

model BankAuthorization {
  id                      String                  @id @default(cuid())
  propertyId              String
  property                Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  provider                String
  state                   String                  @unique
  bankName                String
  country                 String
  psuType                 String                  @default("business")
  status                  BankAuthorizationStatus @default(PENDING)
  externalAuthorizationId String?
  externalSessionId       String?
  providerContextEncrypted String?
  connectedById          String?
  connectedBy            User? @relation("BankAuthorizationConnector", fields: [connectedById], references: [id], onDelete: SetNull)
  expiresAt               DateTime
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([propertyId, status])
  @@index([connectedById])
}

model BankAccount {
  id                 String               @id @default(cuid())
  propertyId         String
  property           Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  ownerId            String?
  owner              Owner?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  provider           String
  bankName           String
  accountName        String?
  iban               String?
  ibanMasked         String
  currency           String               @default("CZK")
  externalAccountId  String
  externalSessionId  String?
  credentialsEncrypted String?
  connectedById      String?
  connectedBy        User? @relation("BankAccountConnector", fields: [connectedById], references: [id], onDelete: SetNull)
  identificationHash String?
  connectionStatus   BankConnectionStatus @default(CONNECTED)
  consentExpiresAt   DateTime?
  balanceCents       Int?
  balanceUpdatedAt   DateTime?
  lastSyncedAt       DateTime?
  lastSyncAttemptAt  DateTime?
  lastSyncError      String?
  autoSyncEnabled    Boolean              @default(true)
  transactions       BankTransaction[]
  matchingRules      BankMatchingRule[]

  @@index([propertyId])
  @@index([ownerId])
  @@index([provider, identificationHash])
  @@index([connectedById])
  @@unique([provider, externalAccountId])
}

model BankMatchingRule {
  id                       String          @id @default(cuid())
  propertyId               String
  property                 Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bankAccountId            String?
  bankAccount              BankAccount?    @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  name                     String
  action                   MatchRuleAction
  priority                 Int             @default(100)
  active                   Boolean         @default(true)
  counterpartyIban         String?
  counterpartyNameContains String?
  variableSymbol           String?
  messageContains          String?
  amountCents              Int?
  targetLeaseId            String?
  targetLease              Lease?          @relation("RuleTargetLease", fields: [targetLeaseId], references: [id], onDelete: Cascade)
  matchedTransactions      BankTransaction[] @relation("MatchedRule")
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([propertyId, active, priority])
  @@index([bankAccountId])
  @@index([targetLeaseId])
}

model BankTransaction {
  id               String              @id @default(cuid())
  bankAccountId    String
  bankAccount      BankAccount         @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  externalId       String
  bookedAt         DateTime
  amountCents      Int
  currency         String              @default("CZK")
  counterpartyName String?
  counterpartyIban String?
  variableSymbol   String?
  message          String?
  status           PaymentStatus       @default(UNMATCHED)
  matchedRuleId    String?
  matchedRule      BankMatchingRule?   @relation("MatchedRule", fields: [matchedRuleId], references: [id], onDelete: SetNull)
  suggestedLeaseId String?
  suggestedLease   Lease?              @relation("SuggestedLease", fields: [suggestedLeaseId], references: [id], onDelete: SetNull)
  matchNote        String?
  allocations      PaymentAllocation[]
  createdAt        DateTime            @default(now())

  @@unique([bankAccountId, externalId])
  @@index([bankAccountId, bookedAt])
  @@index([matchedRuleId])
  @@index([suggestedLeaseId])
}

model PaymentAllocation {
  id            String          @id @default(cuid())
  transactionId String
  chargeId      String
  amountCents   Int
  transaction   BankTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  charge        Charge          @relation(fields: [chargeId], references: [id], onDelete: Cascade)

  @@unique([transactionId, chargeId])
  @@index([chargeId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}
